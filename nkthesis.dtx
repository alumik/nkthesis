%
%    \begin{macrocode}
\labelformat { subfigure } { \thefigure（\thesubfigure） }
\labelformat { equation  } { （\theequation）            }
\AtBeginDocument {
    \crefname{ equation      } { 式    } { 式    }
    \crefname{ figure        } { 图    } { 图    }
    \crefname{ subfigure     } { 子图  } { 子图  }
    \crefname{ table         } { 表    } { 表    }
    \crefname{ page          } { 页    } { 页    }
    \crefname{ chapter       } { 章    } { 章    }
    \crefname{ section       } { 节    } { 节    }
    \crefname{ subsection    } { 小节  } { 小节  }
    \crefname{ subsubsection } { 子节  } { 子节  }
    \crefname{ appendix      } { 附录  } { 附录  }
    \crefname{ theorem       } { 定理  } { 定理  }
    \crefname{ lemma         } { 引理  } { 引理  }
    \crefname{ corollary     } { 推论  } { 推论  }
    \crefname{ proposition   } { 命题  } { 命题  }
    \crefname{ definition    } { 定义  } { 定义  }
    \crefname{ example       } { 例    } { 例    }
    \crefname{ algorithm     } { 算法  } { 算法  }
    \crefname{ listing       } { 列表  } { 列表  }
    \crefname{ line          } { 行    } { 行    }
    \crefformat { page          } { #2第#1页#3   }
    \crefformat { chapter       } { #2第#1章#3   }
    \crefformat { section       } { #2第#1节#3   }
    \crefformat { subsection    } { #2第#1小节#3 }
    \crefformat { subsubsection } { #2第#1子节#3 }
    \crefformat { equation      } { 式#2#1#3     }
    \crefformat { subfigure     } { 图#2#1#3     }
    \crefrangeformat { page          } { #3第#1页#4至#5第#2页#6     }
    \crefrangeformat { chapter       } { #3第#1章#4至#5第#2章#6     }
    \crefrangeformat { section       } { #3第#1节#4至#5第#2节#6     }
    \crefrangeformat { subsection    } { #3第#1小节#4至#5第#2小节#6 }
    \crefrangeformat { subsubsection } { #3第#1子节#4至#5第#2子节#6 }
    \crefmultiformat { page          }
        { #2第#1页#3     } { 和#2第#1页#3   }
        { ，#2第#1页#3   } { 和#2第#1页#3   }
    \crefmultiformat { chapter       }
        { #2第#1章#3     } { 和#2第#1章#3   }
        { ，#2第#1章#3   } { 和#2第#1章#3   }
    \crefmultiformat { section       }
        { #2第#1节#3     } { 和#2第#1节#3   }
        { ，#2第#1节#3   } { 和#2第#1节#3   }
    \crefmultiformat { subsection    }
        { #2第#1小节#3   } { 和#2第#1小节#3 }
        { ，#2第#1小节#3 } { 和#2第#1小节#3 }
    \crefmultiformat { subsubsection }
        { #2第#1子节#3   } { 和#2第#1子节#3 }
        { ，#2第#1子节#3 } { 和#2第#1子节#3 }
    \crefrangemultiformat { page          }
        { #3第#1页#4至#5第#2页#6       } { 和#3第#1页#4至#5第#2页#6     }
        { ，#3第#1页#4至#5第#2页#6     } { 和#3第#1页#4至#5第#2页#6     }
    \crefrangemultiformat { chapter       }
        { #3第#1章#4至#5第#2章#6       } { 和#3第#1章#4至#5第#2章#6     }
        { ，#3第#1章#4至#5第#2章#6     } { 和#3第#1章#4至#5第#2章#6     }
    \crefrangemultiformat { section       }
        { #3第#1节#4至#5第#2节#6       } { 和#3第#1节#4至#5第#2节#6     }
        { ，#3第#1节#4至#5第#2节#6     } { 和#3第#1节#4至#5第#2节#6     }
    \crefrangemultiformat { subsection    }
        { #3第#1小节#4至#5第#2小节#6   } { 和#3第#1小节#4至#5第#2小节#6 }
        { ，#3第#1小节#4至#5第#2小节#6 } { 和#3第#1小节#4至#5第#2小节#6 }
    \crefrangemultiformat { subsubsection }
        { #3第#1子节#4至#5第#2子节#6   } { 和#3第#1子节#4至#5第#2子节#6 }
        { ，#3第#1子节#4至#5第#2子节#6 } { 和#3第#1子节#4至#5第#2子节#6 }
    \cs_set:Npn \crefpairconjunction        { ~和~ }
    \cs_set:Npn \crefmiddleconjunction      { ，   }
    \cs_set:Npn \creflastconjunction        { ~和~ }
    \cs_set:Npn \crefpairgroupconjunction   { ~和~ }
    \cs_set:Npn \crefmiddlegroupconjunction { ，   }
    \cs_set:Npn \creflastgroupconjunction   { ~和~ }
    \cs_set:Npn \crefrangeconjunction       { ~至~ }
}

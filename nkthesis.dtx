% \subsubsection{私有命令定义}
%
% \begin{macro}{\@@_checked_checkbox:, \@@_checkbox:nn, \@@_checkbox:en}
%
% \changes{v2.2}{2025/05/23}{修复命令参数类型标记。}
%
% 根据选项值为复选框打勾。
%
%    \begin{macrocode}
\cs_new_protected:Nn \@@_checked_checkbox: {
    \makebox [ 0pt ] [ l ] { $\square$ }
    \raisebox { 0.15ex } { \hspace { 0.1em } $\checkmark$ }
}
\cs_new_protected:Nn \@@_checkbox:nn {
    \str_if_eq:nnTF {#1} {#2}
        { \@@_checked_checkbox: }
        { $\square$ }
}
\cs_generate_variant:Nn \@@_checkbox:nn { e }
%    \end{macrocode}

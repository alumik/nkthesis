%
% \changes{v2026.3}{2026/03/17}{调整论文前置页面元素的对齐方式和间距。}
%
% \begin{macro}{\@@_item:nnn}
%
% \changes{v2.1}{2025/05/09}{如果题名页键值对中某个条目为空，则显示空的下划线。}
%
% 带下划线的题名页键值对样式。
%
%    \begin{macrocode}
\cs_new_protected:Nn \@@_item:nnn {
    #1 \hspace { 0.5em }
    \underline { \parbox [ b ] {#3} { \centering \vphantom { 字 } #2 } }
}
%    \end{macrocode}
% \end{macro}
%
% \changes{v2026.2}{2026/03/14}{抛弃传统字符串处理宏包，使用 \pkg{l3regex} 重构简单引用命令。}
% \changes{v2.4}{2025/12/28}{修复使用 \cs{simpleref} 引用子图和公式时显示为空的问题。}
% \changes{v2026.3}{2026/03/15}{使用 \pkg{cleveref} 宏包提供的接口设置交叉引用名称和格式。移除原有的 \cs{simpleref} 等命令。}
%
% \changes{v2026.1}{2026/03/12}{使用更加鲁棒的实现方式重构《南开大学学位论文原创性声明》页面与《南开大学学位论文使用授权书》页面。}
%
% \begin{macro}{\@@_apply_align:nn}
%
% 表辅助函数：根据指定的对齐方式应用相应的水平对齐命令。
%
%    \begin{macrocode}
\cs_new_protected:Nn \@@_apply_align:nn {
    \str_case:nnF {#1} {
        { c } { \centering #2 }
        { l } { \raggedright #2 }
        { r } { \raggedleft #2 }
        { s } { \makebox [ \linewidth ] [ s ] {#2} }
    }
    {#2}
}
%    \end{macrocode}
% \end{macro}
%
% \begin{macro}{\@@_make_cell:nnn}
%
% 表辅助函数：统一处理带固定宽度的表格单元格。
%
%    \begin{macrocode}
\cs_new_protected:Nn \@@_make_cell:nnnnn {
    \makebox [#1] [ c ] {
        \tl_if_empty:nTF
            {#2}
            {
                \parbox [ c ] { \dim_eval:n { #1 - #3 - #3 } }
                    {
                        \vspace { 1.4mm }
                        \@@_apply_align:nn {#4} {#5}
                        \vspace { 1.4mm }
                    }
            }
            {
                \parbox [ c ] [#2] [ c ] { \dim_eval:n { #1 - #3 - #3 } }
                    {
                        \vspace { 1.4mm }
                        \@@_apply_align:nn {#4} {#5}
                        \vspace { 1.4mm }
                    }
            }
    }
}
%    \end{macrocode}
% \end{macro}
%
% \subsubsection{公有命令定义}
%
% \changes{v2026.1}{2026/03/12}{调整行间距时不再需要使用 \texttt{\textbackslash selectfont}。}
%
% \begin{macro}{\mslinespread}
%
% Microsoft Word 多倍行距模拟。
%
%    \begin{macrocode}
\NewDocumentCommand \mslinespread { m } {
    \linespread {
        \fp_eval:n {
            #1 *
            \@@_keys_get:nn { typesetting } { ms-base-linespread } /
            1.2
        }
    }
    \selectfont
}
%    \end{macrocode}
% \end{macro}
%
% \begin{macro}{\mslinespreadbp}
%
% Microsoft Word 固定行距模拟。
%
%    \begin{macrocode}
\NewDocumentCommand \mslinespreadbp { m m } {
    \linespread { \fp_eval:n { #1 / #2 / 1.2 } }
    \selectfont
}
%    \end{macrocode}
% \end{macro}
%
% \subsection{文档结构}
%
% \changes{v2.4}{2026/01/06}{使用大写字母作为封面页和声明页的页码编号，避免正文中产生重复页码对象。}
%
% 使用大写字母作为封面页和声明页的页码编号，避免正文中产生重复页码对象。
%
%    \begin{macrocode}
\AtBeginDocument { \pagenumbering { Alph } }
%    \end{macrocode}
%
% \changes{v2.2}{2025/05/23}{支持章节仅从奇数页开始。}
%
% \begin{macro}{\frontmatter}
%
% \changes{v2.2}{2025/05/23}{将前置部分的页面风格设置为 \texttt{fancy}。}
%
%    \begin{macrocode}
\RenewDocumentCommand \frontmatter { } {
    \bool_if:NTF \l_@@_openright_bool
        { \cleardoublepage }
        { \clearpage }
    \pagenumbering { Roman }
    \pagestyle { fancy }
    \int_gset:Nn \c@page { 1 }
    \ctexset {
        chapter/format = {
            \mslinespread { 1 }
            \heiti
            \zihao { 3 }
            \bfseries
            \centering
        },
    }
}
%    \end{macrocode}
% \end{macro}
%
% \changes{v2.2}{2025/05/23}{支持章节仅从奇数页开始。}
%
% \begin{macro} {\mainmatter}
%    \begin{macrocode}
\RenewDocumentCommand \mainmatter { } {
    \bool_if:NTF \l_@@_openright_bool
        { \cleardoublepage }
        { \clearpage }
    \pagenumbering { arabic }
    \pagestyle { fancy }
    \int_gset:Nn \c@page { 1 }
    \int_compare:nNnT \l_@@_headingmode_int = 1 {
        \ctexset {
            chapter/format = {
                \mslinespread { 1 }
                \heiti
                \zihao { 3 }
                \bfseries
            },
        }
    }
}
%    \end{macrocode}
% \end{macro}
%
% \changes{v2.2}{2025/05/23}{支持章节仅从奇数页开始。}
%
% \begin{macro}{\backmatter}
%    \begin{macrocode}
\RenewDocumentCommand \backmatter { } {
    \bool_if:NTF \l_@@_openright_bool
        { \cleardoublepage }
        { \clearpage }
    \pagestyle { fancy }
    \ctexset {
        chapter/format = {
            \mslinespread { 1 }
            \heiti
            \zihao { 3 }
            \bfseries
            \centering
        },
    }
}
%    \end{macrocode}
% \end{macro}

%
% \subsection{载入基础类和包}
%
% 启用 \pkg{xeCJK} 宏包的自动伪粗体和伪斜体功能。
%
% \changes{v2.3}{2025/12/24}{调整伪粗体和伪斜体的参数，使其效果更接近 Microsoft Word。}
%
%    \begin{macrocode}
\PassOptionsToPackage {
    AutoFakeBold  = \@@_keys_get:nn { typesetting } { fake-bold  },
    AutoFakeSlant = \@@_keys_get:nn { typesetting } { fake-slant },
} { xeCJK }
%    \end{macrocode}
%
% 载入 \cls{ctexbook} 文档类。
% 双面打印时允许章节开始于偶数页。
% 默认字号小四，支持宋体、仿宋、楷体、黑体四种字体。
%
% \changes{v2.1}{2025/05/01}{将字体的定义从 ctex-fontset-nkthesis.def 移到 nkthesis.dtx 中。}
%
%    \begin{macrocode}
\PassOptionsToClass {
    zihao      = -4,
    linespread = \@@_keys_get:nn { typesetting } { default-linespread },
    fontset    = none,
    UTF8,
} { ctexbook }
\bool_if:NF \l_@@_openright_bool
    { \PassOptionsToClass { openany } { ctexbook } }
\LoadClass { ctexbook }
%    \end{macrocode}
%
% 载入宏包。
%
% \changes{v2026.0}{2026/03/12}{删除不必要或重复引入的宏包。}
% \changes{v2026.4}{2026/03/28}{使公式上下间距保持一致。}
%
%    \begin{macrocode}
\RequirePackage [ a4paper ] { geometry }
\RequirePackage [ titles ] { tocloft }
\RequirePackage { caption }
\RequirePackage { fancyhdr }
\RequirePackage { fontspec }
\RequirePackage [ inline, shortlabels ] { enumitem }
\RequirePackage [ hidelinks ] { hyperref }
\RequirePackage { amssymb }
\RequirePackage { mathtools }
\RequirePackage [ nodisplayskipstretch ] { setspace }
\RequirePackage [
    backend = biber,
    style   = gb7714-2015,
    url     = false,
    gbpub   = \bool_to_str:N \l_@@_gbpub_bool,
] { biblatex }
\RequirePackage { subcaption }
\RequirePackage { tikz }
\RequirePackage { array }
\RequirePackage { newunicodechar }
\RequirePackage { cleveref }
%    \end{macrocode}

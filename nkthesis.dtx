% \subsubsection{属性操作命令}
%
% \begin{variable}{\g_@@_config_prop}
%
% 创建属性列表。
%
%    \begin{macrocode}
\prop_new:N \g_@@_config_prop
%    \end{macrocode}
% \end{variable}
%
% \begin{macro}{\@@_config_set:nn, \@@_config_get:n}
%
% 属性写入和读取命令。
%
%    \begin{macrocode}
\cs_new_protected:Nn \@@_config_set:nn
    { \prop_put:Nnn \g_@@_config_prop {#1} {#2} }
\cs_new:Nn \@@_config_get:n
    { \prop_item:Nn \g_@@_config_prop {#1} }
%    \end{macrocode}
% \end{macro}
%
% \begin{macro}{\@@_keys_set:nn, \@@_keys_get:nn}
%
% \changes{v2.3}{2025/12/27}{当键名不存在时直接报错而不是返回空值。}
%
% 键值写入和读取命令。
%
%    \begin{macrocode}
\msg_new:nnn { @@ } { invalid-key }
    { The~key~'#1'~is~not~defined~in~the~nkthesis~class. }
\cs_new_protected:Nn \@@_keys_set:nn
    { \keys_set:nn { @@ / #1 } {#2} }
\cs_new:Nn \@@_keys_get:nn {
    \keys_if_exist:nnTF
        { @@ / #1 }
        {#2}
        { \prop_item:Nn \g_@@_config_prop { #1 / #2 } }
        { \msg_fatal:nnn { @@ } { invalid-key } { #1 / #2 } }
}
%    \end{macrocode}
% \end{macro}
